# ─── Server ───────────────────────────────────────────────
PORT=8080
# Origjina e frontend-it për CORS në prod (p.sh. https://moti.com.al).
# Në prod ku Nginx shërben të njëjtën origjinë, mund ta lësh bosh.
CORS_ORIGIN=https://moti.com.al
NODE_ENV=production

# ─── MariaDB ──────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=moti
DB_PASSWORD=ndrysho_me_nje_fjalekalim_te_forte
DB_NAME=moti

# ─── Auth admin ───────────────────────────────────────────
# Sekret për nënshkrimin e JWT — gjenero me: openssl rand -hex 32
JWT_SECRET=ndrysho_me_openssl_rand_hex_32
# Fjalëkalimi admin ruhet si hash bcrypt. Gjenero hash-in me:
#   node -e "console.log(require('bcryptjs').hashSync('FJALEKALIMI', 10))"
# (ose lëre ADMIN_PASSWORD_HASH bosh dhe vendos ADMIN_PASSWORD për hash automatik në nisje — vetëm për zhvillim)
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=moti2024admin
# Sa zgjat token-i i login-it
JWT_EXPIRES_IN=12h

# ─── MET Norway (weather proxy) ───────────────────────────
# I DETYRUESHËM nga api.met.no — vendos një email real kontakti
MET_USER_AGENT=Moti.com.al contact@moti.com.al
